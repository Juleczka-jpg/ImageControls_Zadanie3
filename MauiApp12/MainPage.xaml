<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp12.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Image x:Name="LocalImage"
                   Source="dotnet_bot.png"
                   HeightRequest="200"
                   Aspect="AspectFit"
                   HorizontalOptions="Center" />

            <Image x:Name="RemoteImage"
                   Aspect="AspectFit"
                   WidthRequest="200"
                   HeightRequest="200"
                   HorizontalOptions="Center" />

            <Image x:Name="GifImage"
                   WidthRequest="200"
                   HeightRequest="200"
                   IsAnimationPlaying="True"/>

            <ImageButton x:Name="ButtonImage"
                         WidthRequest="200"
                         HeightRequest="200"
                         Clicked="OnChangeAspectClicked" />

            <Label x:Name="AspectLabel"
                   Text="Aspect: AspectFit"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
